<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd" >
<suite name="eCommerce Master Suite" verbose="1" preserve-order="true">
    <listeners>
        <listener class-name="framework.listeners.RetryTransformer"></listener>
        <listener class-name="framework.listeners.TestListeners"></listener>
    </listeners>
    <test name="All Tests">
        <packages>
            <package name="tests.*"/>
        </packages>
    </test>
</suite>
